<!DOCTYPE html>
<html>
  <head>
    <title>Anonymisation Schedule Report</title>
    {{> meta}}
  </head>
  <body style="margin: 0;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #F0E8E1; margin: 0; padding: 0; font-family: Arial, sans-serif;">
      <tr>
        <td align="center">
          {{> header}}
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #FFFFFF; border: 1px solid #EAEBED; padding: 40px 30px; border-radius: 12px; max-width: 600px;">
            <tr>
              <td>
                <h1 style="font-size: 24px; color: #3A3131; font-weight: 600; margin: 0 0 20px 0; line-height: 1.3;">Anonymisation Schedule Report</h1>
                <p style="font-size: 16px; color: #3A3131; line-height: 1.5; margin: 0 0 20px 0;">Hello</p>
                <p style="font-size: 16px; color: #3A3131; line-height: 1.5; margin: 0;">
                  Please find attached the list of user who are scheduled for anonymisation on <strong>{{scheduledTimestamp}}</strong>.
                </p>
              </td>
            </tr>
          </table>
          {{> footer}}
        </td>
      </tr>
    </table>
  </body>
</html>
